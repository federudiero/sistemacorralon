rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Desarrollo / bootstrap con login local de esta app.
    // Cuando migres a Firebase Auth real, reemplaza estas rules por version con request.auth.
    match /cuentas/{cuentaId}/{document=**} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
